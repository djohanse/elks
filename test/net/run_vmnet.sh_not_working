#!/usr/bin/env bash
# Interactive ELKS test with vmnet-shared (real network access)
# Requires sudo for macOS vmnet framework.
set -e
cd "$(dirname "$0")"

IMAGE="../../image/fd1440.img"
[ -f "$IMAGE" ] || IMAGE="../../image/fd2880.img"
[ -f "$IMAGE" ] || { echo "No ELKS image found!"; exit 1; }

QEMU="${QEMU:-qemu-system-x86_64}"
ACCEL="${ACCEL:--accel tcg}"

echo "================================================"
echo "  ELKS with vmnet-shared (real network access)"
echo "================================================"
echo ""
echo "  In the ELKS shell that opens:"
echo ""
echo "    1. Configure networking:"
echo "       ifconfig 10.0.2.15 netmask 255.255.255.0 gateway 10.0.2.1"
echo ""
echo "    2. Start ktcp (TCP/IP stack):"
echo "       ktcp &"
echo ""
echo "    3. Test with ping:"
echo "       ping -c 3 8.8.8.8"
echo "       ping -c 3 google.com"
echo ""
echo "    4. Test traceroute:"
echo "       traceroute 8.8.8.8"
echo "       traceroute google.com"
echo ""
echo "  Ctrl+C to stop QEMU."
echo "================================================"
echo ""

exec sudo "$QEMU" $ACCEL -nodefaults -machine isapc -cpu 486,tsc -m 8M \
    -serial mon:stdio \
    -netdev vmnet-shared,id=net0,start-address=10.0.2.15,end-address=10.0.2.15,subnet-mask=255.255.255.0 \
    -device ne2k_isa,irq=12,netdev=net0 \
    -snapshot \
    -fda "$IMAGE"
